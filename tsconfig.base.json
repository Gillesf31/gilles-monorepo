{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@gilles-monorepo/recipe-data-access": [
        "libs/recipe/data-access/src/index.ts"
      ],
      "@gilles-monorepo/feature-list": [
        "libs/recipe/feature-list/src/index.ts"
      ],
      "@gilles-monorepo/shell": ["libs/recipe/shell/src/index.ts"],
      "@gilles-monorepo/recipe-model": ["libs/recipe/model/src/index.ts"],
      "@gilles-monorepo/feature-add": ["libs/recipe/feature-add/src/index.ts"],
      "@gilles-monorepo/feature-detail": [
        "libs/recipe/feature-detail/src/index.ts"
      ],
      "@gilles-monorepo/feature-edit": [
        "libs/recipe/feature-edit/src/index.ts"
      ],
      "@gilles-monorepo/recipe-ui": ["libs/recipe/ui/src/index.ts"],
      "@gilles-monorepo/feature-shopping-list": [
        "libs/recipe/feature-shopping-list/src/index.ts"
      ],
      "@gilles-monorepo/feature-theme": [
        "libs/shared/feature-theme/src/index.ts"
      ],
      "@gilles-monorepo/util-supabase": [
        "libs/shared/util-supabase/src/index.ts"
      ],
      "@gilles-monorepo/feature-app-version": [
        "libs/recipe/feature-app-version/src/index.ts"
      ],
      "@gilles-monorepo/recipe-ingredient-ui": [
        "libs/recipe/ingredient-ui/src/index.ts"
      ],
      "@gilles-monorepo/recipe-card-ui": ["libs/recipe/card-ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
