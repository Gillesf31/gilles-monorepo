{
  "name": "recipe-card-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/recipe/card-ui/src",
  "prefix": "gilles-monorepo",
  "projectType": "library",
  "tags": ["type:ui", "scope:recipe"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 6008,
        "configDir": "libs/recipe/card-ui/.storybook",
        "browserTarget": "recipe:build:development",
        "compodoc": false,
        "styles": ["apps/recipe/src/styles.css"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/recipe-card-ui",
        "configDir": "libs/recipe/card-ui/.storybook",
        "browserTarget": "recipe:build:production",
        "compodoc": false,
        "styles": ["apps/recipe/src/styles.css"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    }
  }
}
