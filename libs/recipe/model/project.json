{
  "name": "recipe-model",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/recipe/model/src",
  "prefix": "gilles-monorepo",
  "projectType": "library",
  "tags": ["type:model", "scope:recipe"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/recipe/model/ng-package.json",
        "tsConfig": "libs/recipe/model/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/recipe/model/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
